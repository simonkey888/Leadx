{
  "name": "leadx-light-crm-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run test:existing && npm run test:new",
    "test:existing": "node scripts/run-tests.mjs && node scripts/containment-tests.mjs && node scripts/session-tests.mjs",
    "test:new": "node scripts/security-runtime-tests.mjs && node scripts/repository-scan.mjs",
    "test:containment": "node scripts/containment-tests.mjs",
    "test:session": "node scripts/session-tests.mjs",
    "test:security": "node scripts/security-runtime-tests.mjs",
    "scan": "node scripts/repository-scan.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
